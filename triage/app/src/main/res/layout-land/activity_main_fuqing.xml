<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="#D2ECF9"
    tools:ignore="MissingDefaultResource">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="118px">

        <ImageView
            android:id="@+id/iv_logo"
            android:layout_width="285px"
            android:layout_height="86px"
            android:layout_centerVertical="true"
            android:layout_marginLeft="@dimen/margin40"
            android:scaleType="fitCenter"
            android:src="@drawable/logo" />

        <ImageView
            android:id="@+id/iv_state"
            android:layout_width="86px"
            android:layout_height="86px"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:layout_marginRight="@dimen/margin10"
            app:srcCompat="@drawable/ic_close"
            android:visibility="invisible"/>

        <TextView
            android:id="@+id/tv_time"
            style="@style/time_fuqing"
            android:layout_marginRight="@dimen/margin20"
            android:layout_toLeftOf="@+id/iv_state"
            tools:text="09:20" />

        <TextView
            android:id="@+id/tv_weekday"
            style="@style/time_fuqing"
            android:layout_marginLeft="@dimen/margin10"
            android:layout_marginRight="@dimen/margin10"
            android:layout_toLeftOf="@+id/tv_time"
            tools:text="星期四" />

        <TextView
            android:id="@+id/tv_date"
            style="@style/time_fuqing"
            android:layout_toLeftOf="@+id/tv_weekday"
            tools:text="2018年07月12时" />
    </RelativeLayout>
    <LinearLayout
        android:id="@+id/content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginLeft="30px"
        android:layout_marginRight="30px"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:background="@drawable/shape_gradient_1_fuqing">
    </LinearLayout>
    <com.wcjk.triage.common.AutoScrollTextView
        android:id="@+id/tv_run"
        android:layout_width="match_parent"
        android:layout_height="60px"
        android:layout_marginLeft="30px"
        android:layout_marginRight="30px"
        android:layout_marginTop="@dimen/margin15"
        android:gravity="center_vertical"
        android:textColor="#57585A"
        android:textSize="42px"
        android:text="感谢您耐心等待。"/>
</LinearLayout>