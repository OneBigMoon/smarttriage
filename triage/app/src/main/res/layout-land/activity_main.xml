<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="#D2ECF9"
    tools:ignore="MissingDefaultResource">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/title_land_h"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent">
        <ImageView
            android:id="@+id/iv_logo"
            android:layout_width="285px"
            android:layout_height="86px"
            android:layout_centerVertical="true"
            android:layout_marginLeft="@dimen/margin20"
            android:scaleType="fitCenter"
            android:src="@drawable/logo" />
        <ImageView
            android:id="@+id/iv_state"
            android:layout_width="86px"
            android:layout_height="86px"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:layout_marginRight="@dimen/margin10"
            app:srcCompat="@drawable/ic_close"
            android:visibility="invisible"/>

        <TextView
            android:id="@+id/tv_time"
            style="@style/time"
            android:layout_centerVertical="true"
            android:layout_marginRight="@dimen/margin20"
            android:layout_toLeftOf="@+id/iv_state"
            tools:text="09:20" />

        <TextView
            android:id="@+id/tv_weekday"
            style="@style/time"
            android:layout_centerVertical="true"
            android:layout_marginLeft="@dimen/margin10"
            android:layout_marginRight="@dimen/margin10"
            android:layout_toLeftOf="@+id/tv_time"
            tools:text="星期四" />

        <TextView
            android:id="@+id/tv_date"
            style="@style/time"
            android:layout_centerVertical="true"
            android:layout_toLeftOf="@+id/tv_weekday"
            tools:text="2018年07月12时" />
    </RelativeLayout>
    <android.support.v7.widget.CardView
        android:id="@+id/content"
        android:layout_width="1840px"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginLeft="@dimen/margin40"
        android:layout_marginRight="@dimen/margin40"
        android:layout_gravity="center_horizontal"
        card_view:cardCornerRadius="30px"
        card_view:cardElevation="0px"
        card_view:cardBackgroundColor="@color/color_FFF4F5F9_50">
        <!--<include layout="@layout/second_item"/>-->
    </android.support.v7.widget.CardView>
    <com.wcjk.triage.common.AutoScrollTextView
        android:id="@+id/tv_run"
        android:layout_width="match_parent"
        android:layout_height="@dimen/autoscrollview_sport_h"
        android:layout_marginLeft="30px"
        android:layout_marginRight="30px"
        android:layout_marginTop="@dimen/margin20"
        android:textColor="#FF063C4B"
        android:textSize="@dimen/text_size48"
        android:gravity="center_vertical"/>
</LinearLayout>