<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">
    <!--<LinearLayout-->
        <!--style="@style/setting_line"-->
        <!--android:layout_below="@+id/ll2"-->
        <!--android:orientation="horizontal">-->
        <!--<TextView-->
            <!--style="@style/setting_text1"-->
            <!--android:text="设备编号设置："/>-->
        <!--<EditText-->
            <!--android:id="@+id/et1"-->
            <!--style="@style/setting_text2"-->
            <!--android:text=""/>-->
    <!--</LinearLayout>-->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/settings_line_h"
        android:orientation="horizontal">
        <TextView
            style="@style/setting_text1"
            android:text="开机时间：" />
        <RelativeLayout
            style="@style/setting_text2">
            <TextView
                android:id="@+id/tv1"
                style="@style/setting_edit"/>
            <ImageView
                style="@style/settings_drop_button"
                app:srcCompat="@drawable/ic_down"/>
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/text4"
                android:layout_alignParentBottom="true"/>
        </RelativeLayout>
    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/settings_line_h"
        android:orientation="horizontal">
        <TextView
            style="@style/setting_text1"
            android:text="关机时间：" />
        <RelativeLayout
            style="@style/setting_text2">
            <TextView
                android:id="@+id/tv2"
                style="@style/setting_edit"/>
            <ImageView
                style="@style/settings_drop_button"
                app:srcCompat="@drawable/ic_down"/>
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/text4"
                android:layout_alignParentBottom="true"/>
        </RelativeLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/settings_line_h"
        android:orientation="horizontal">
        <TextView
            style="@style/setting_text1"
            android:text="旋转度设置：" />
        <RelativeLayout
            style="@style/setting_text2">
            <TextView
                android:id="@+id/tv3"
                style="@style/setting_edit"/>
            <ImageView
                style="@style/settings_drop_button"
                app:srcCompat="@drawable/ic_down"/>
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/text4"
                android:layout_alignParentBottom="true"/>
        </RelativeLayout>
    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/settings_line_h"
        android:orientation="horizontal">
        <TextView
            style="@style/setting_text1"
            android:text="音量大小：" />
        <RelativeLayout
            style="@style/setting_text2">
            <TextView
                android:id="@+id/tv4"
                style="@style/setting_edit"/>
            <ImageView
                style="@style/settings_drop_button"
                app:srcCompat="@drawable/ic_down"/>
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/text4"
                android:layout_alignParentBottom="true"/>
        </RelativeLayout>
    </LinearLayout>
    <LinearLayout
        style="@style/setting_line_btn">
        <Button
            android:id="@+id/btn_restart"
            style="@style/setting_button1"
            android:text="重启" />
        <Button
            android:id="@+id/btn_ok"
            style="@style/setting_button2"
            android:text="确定"/>
    </LinearLayout>
</LinearLayout>