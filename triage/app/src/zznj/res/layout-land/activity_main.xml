<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@drawable/shape_gradient_1"
    tools:ignore="MissingDefaultResource">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/title_land_h"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent">
        <ImageView
            android:id="@+id/iv_logo"
            android:layout_width="285px"
            android:layout_height="86px"
            android:layout_centerVertical="true"
            android:layout_marginLeft="@dimen/margin40"
            android:scaleType="fitCenter"
            android:src="@drawable/logo" />

        <com.wcjk.triage.common.MarqueeText
            android:id="@+id/tv_title"
            android:layout_width="420dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="12dp"
            android:layout_marginRight="50px"
            android:layout_marginBottom="10px"
            android:layout_toLeftOf="@+id/tv_date"
            android:layout_toRightOf="@+id/iv_logo"
            android:background="@mipmap/bg_title"
            android:ellipsize="marquee"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:gravity="center"
            android:singleLine="true"
            android:textColor="#F66B4E"
            android:textSize="80px"
            android:textStyle="bold" />
        <ImageView
            android:id="@+id/iv_state"
            android:layout_width="60px"
            android:layout_height="60px"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:layout_marginRight="@dimen/margin10"
            app:srcCompat="@drawable/ic_close"
            android:visibility="invisible"/>

        <TextView
            android:id="@+id/tv_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_size48"
            android:textColor="#063C4B"
            android:layout_marginRight="@dimen/margin10"
            android:layout_toLeftOf="@+id/iv_state"
            tools:text="09:20" />
        <TextView
            android:id="@+id/tv_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="@dimen/margin15"
            android:textSize="@dimen/text_size30"
            android:textColor="#063C4B"
            android:layout_below="@+id/tv_time"
            android:layout_toLeftOf="@+id/tv_weekday"
            tools:text="2018年07月12时" />
        <TextView
            android:id="@+id/tv_weekday"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_size30"
            android:textColor="#063C4B"
            android:layout_alignBaseline="@+id/tv_date"
            android:layout_alignRight="@+id/tv_time"
            tools:text="星期四" />
    </RelativeLayout>
    <android.support.v7.widget.CardView
        android:id="@+id/content"
        android:layout_width="1840px"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginLeft="@dimen/margin40"
        android:layout_marginRight="@dimen/margin40"
        android:layout_gravity="center_horizontal"
        card_view:cardCornerRadius="15px"
        card_view:cardElevation="0px"
        >
        <ImageView
            android:background="#27BDFC"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

        </ImageView>
        <!--<include layout="@layout/second_item"/>-->
    </android.support.v7.widget.CardView>
    <com.wcjk.triage.common.AutoScrollTextView
        android:id="@+id/tv_run"
        android:layout_width="match_parent"
        android:layout_height="@dimen/autoscrollview_sport_h"
        android:layout_marginLeft="30px"
        android:layout_marginRight="30px"
        android:layout_marginTop="@dimen/margin20"
        android:textColor="#FF063C4B"
        android:textSize="@dimen/text_size48" />
</LinearLayout>